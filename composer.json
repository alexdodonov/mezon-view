{
	"name": "mezon/view",
	"description": "View classes",
	"license": "MIT",
	"authors": [
		{
			"name": "Dodonov Alexey",
			"email": "alexey@dodonov.pro",
			"homepage": "http://gdzone.ru",
			"role": "Founder"
		}
	],
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"vimeo/psalm": "^5.22",
		"infection/infection": "^0.27|^0.28",
		"rregeer/phpunit-coverage-check": "0.3.1"
	},
	"require": {
		"php": ">=8.2.0",
		"mezon/http-request-params": "1.0.*",
		"mezon/html-template": "1.1.*",
		"mezon/request": ">=1.0.3 <1.1.0"
	},
	"support": {
		"email": "alexey@dodonov.pro",
		"issues": "https://github.com/alexdodonov/mezon-view/issues",
		"source": "https://github.com/alexdodonov/mezon-view"
	},
	"minimum-stability": "dev",
	"homepage": "https://github.com/alexdodonov/mezon-view",
	"prefer-stable": true,
	"autoload": {
		"psr-4": {
			"Mezon\\": "./Mezon/",
			"Mezon\\View\\Tests\\": "./Mezon/View/Tests/"
		}
	},
	"scripts": {
		"test-self": [
			"php ./vendor/phpunit/phpunit/phpunit --testsuite=self --order-by=random",
			"php ./vendor/rregeer/phpunit-coverage-check/bin/coverage-check ./Tmp/coverage.xml 93"
		],
		"test": [
			"php ./vendor/phpunit/phpunit/phpunit --order-by=random",
			"php ./vendor/rregeer/phpunit-coverage-check/bin/coverage-check ./Tmp/coverage.xml 93"
		],
		"psalm-self": "php ./vendor/vimeo/psalm/psalm --show-info=true --no-cache --config=psalm-self.xml",
		"psalm": "php ./vendor/vimeo/psalm/psalm --show-info=true --no-cache",
		"infection-self": "php ./vendor/infection/infection/bin/infection --threads=4 --min-msi=83 --test-framework-options=\"--testsuite=self\"",
		"infection": "php ./vendor/infection/infection/bin/infection --threads=4 --min-msi=82",
		"debug": "php ./vendor/phpunit/phpunit/phpunit --order-by=random --random-order-seed=1640270490"
	},
	"config": {
		"allow-plugins": {
			"infection/extension-installer": true
		}
	}
}
